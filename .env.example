# Salin file ini jadi .env.local (untuk development di komputer sendiri)
# lalu isi 3 nilai di bawah dari Supabase Dashboard > Project Settings > API.
#
# Untuk production (Vercel), 3 variable ini harus ditambahkan juga di:
# Vercel Project > Settings > Environment Variables

# Project Settings > General > Project URL (atau bentuk https://<project-id>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Project Settings > API Keys > Publishable key (sb_publishable_...)
# Aman ditanam di kode browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Project Settings > API Keys > Secret key (sb_secret_...)
# RAHASIA. Jangan pernah dikirim ke browser / commit ke git.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxx

# URL situs kamu (dipakai buat bikin link aktivasi acak yang dikasih ke
# pendaftar baru, mis. https://teamsopan.vercel.app/masuk?token=...).
# Development lokal: http://localhost:3000
# Production: URL Vercel/domain asli kamu, TANPA garis miring di akhir.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email SATU-SATUNYA akun yang boleh akses /dashboard. Harus sama persis
# (case-insensitive) dengan email login admin di Supabase Auth. Kalau
# kosong/belum diisi, TIDAK ADA yang bisa akses /dashboard sama sekali.
ADMIN_EMAIL=admints@teamsopan.com
